DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Postgres
DB_NAME=aria_db
DB_USER=aria_user
DB_PASSWORD=aria_pass
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM (OpenRouter — used by LangGraph agents)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Web search (Tavily — Advocate & Critic agents)
TAVILY_API_KEY=tvly-your-tavily-key-here

# Frontend URL (OAuth redirect after Google login)
FRONTEND_URL=http://localhost:5173

# Google OAuth — required for "Continue with Google"
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8000/accounts/google/login/callback/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173
